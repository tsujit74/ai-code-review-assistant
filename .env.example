```env
# ==========================================
# Database
# ==========================================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/code_review_db?schema=public

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# ==========================================
# Server Configuration
# ==========================================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ==========================================
# File Upload Configuration
# ==========================================
MAX_FILE_SIZE=52428800
MAX_ZIP_SIZE=104857600
UPLOAD_DIR=./uploads

# ==========================================
# Default AI Provider (Optional)
# ==========================================
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=your-openai-api-key
AI_PROVIDER_MODEL_NAME=gpt-4.1-mini

# ==========================================
# Alternative Provider Example (Groq)
# Uncomment if using Groq instead of OpenAI
# ==========================================
# AI_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
# AI_PROVIDER_API_KEY=your-groq-api-key
# AI_PROVIDER_MODEL_NAME=llama-3.3-70b-versatile

# ==========================================
# Local Provider Example (LM Studio)
# Uncomment if using LM Studio locally
# ==========================================
# AI_PROVIDER_BASE_URL=http://localhost:1234/v1
# AI_PROVIDER_API_KEY=lm-studio
# AI_PROVIDER_MODEL_NAME=mistral-7b-instruct

# ==========================================
# Local Provider Example (Ollama)
# Uncomment if using Ollama locally
# ==========================================
# AI_PROVIDER_BASE_URL=http://localhost:11434/v1
# AI_PROVIDER_API_KEY=ollama
# AI_PROVIDER_MODEL_NAME=llama3.1
```
